# Copy to .env and fill in. Loaded by config/settings/base.py via django-environ.

# --- Core ---
DEBUG=True
SECRET_KEY=change-me-with-`python -c "import secrets;print(secrets.token_urlsafe(64))"`
ALLOWED_HOSTS=*

# --- Database (Postgres; django-tenants requires Postgres) ---
DATABASE_URL=postgres://starforge:starforge@localhost:5432/starforge

# --- Redis (cache, channels, celery) ---
REDIS_URL=redis://localhost:6379/0
CHANNEL_REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# --- CORS / CSRF ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://*.localhost:8000

# --- S3-compatible storage (MinIO in dev, AWS S3 in prod) ---
AWS_STORAGE_BUCKET_NAME=starforge-media
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_ACCESS_KEY_ID=minioadmin
AWS_S3_SECRET_ACCESS_KEY=minioadmin
AWS_S3_REGION_NAME=us-east-1

# --- Eskiz SMS (Uzbek SMS provider) ---
ESKIZ_API_URL=https://notify.eskiz.uz/api
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546                 # (new, O-1) approved sender nick; 4546 = Eskiz test sender
ESKIZ_USE_MOCK=True

# --- Proxy trust ---
# Trusted reverse-proxy hops for X-Forwarded-For (IP throttles + client_ip).
# 0 when the app is exposed directly (dev); 1 behind nginx/traefik.
NUM_PROXIES=0

# --- Anthropic (AI) ---
ANTHROPIC_API_KEY=

# --- Field encryption (O-11; TD-11). Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Dev/test auto-generate a throwaway key; staging/prod REQUIRE a real one. Never commit it.
FIELD_ENCRYPTION_KEY=

# --- Observability (O-10). Empty = disabled. ---
SENTRY_DSN=

# --- Email ---
DEFAULT_FROM_EMAIL=noreply@starforge.uz
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False

# --- Dev toggles ---
DEBUG_SQL=False
