# Restic encrypts every backup. Keep offsite mode for durable disaster recovery.
BACKUP_MODE=offsite
RESTIC_HOST=starforge-production
RESTIC_REPOSITORY=s3:https://offsite-object-storage.example.com/starforge-backups
RESTIC_PASSWORD=GENERATE_A_LONG_UNIQUE_BACKUP_PASSWORD
AWS_ACCESS_KEY_ID=REPLACE_WITH_BACKUP_ONLY_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_BACKUP_ONLY_SECRET_KEY
RESTIC_IMAGE=restic/restic:0.18.0@sha256:4cf4a61ef9786f4de53e9de8c8f5c040f33830eb0a10bf3d614410ee2fcb6120
MINIO_MC_IMAGE=minio/mc@sha256:a7fe349ef4bd8521fb8497f55c6042871b2ae640607cf99d9bede5e9bdf11727

# Temporary same-server fallback. It protects against bad deploys, but not host loss.
# BACKUP_MODE=local
# LOCAL_BACKUP_ROOT=/var/backups/starforge
# LOCAL_BACKUP_MIN_FREE_BYTES=5368709120
# RESTIC_REPOSITORY=/repository/restic
# Remove the AWS_* variables when local mode is active.
