DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=False
SECRET_KEY=GENERATE_AT_LEAST_64_RANDOM_CHARACTERS
ALLOWED_HOSTS=api.example.com,tenant.example.com

DATABASE_URL=postgres://starforge:URL_ENCODED_DATABASE_PASSWORD@postgres:5432/starforge
CONN_MAX_AGE=60
REDIS_URL=redis://redis:6379/0
CHANNEL_REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3

CORS_ALLOWED_ORIGINS=https://app.example.com
CSRF_TRUSTED_ORIGINS=https://api.example.com,https://tenant.example.com
NUM_PROXIES=1
WEBSOCKET_ALLOW_QUERY_TOKEN=False

AWS_STORAGE_BUCKET_NAME=starforge-media
AWS_STATIC_BUCKET_NAME=starforge-static
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_PUBLIC_ENDPOINT_URL=https://storage.example.com
AWS_S3_ACCESS_KEY_ID=REPLACE_WITH_NON_ROOT_MINIO_ACCESS_KEY
AWS_S3_SECRET_ACCESS_KEY=REPLACE_WITH_NON_ROOT_MINIO_SECRET_KEY
AWS_S3_REGION_NAME=us-east-1
# Exact browser origins allowed to use presigned media URLs. No wildcard.
STORAGE_CORS_ALLOWED_ORIGINS=https://app.example.com

FIELD_ENCRYPTION_KEY=GENERATE_WITH_FERNET_GENERATE_KEY

ESKIZ_API_URL=https://notify.eskiz.uz/api
SMS_ENABLED=False
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=
AI_ENABLED=False
ANTHROPIC_API_KEY=
FISCALIZATION_ENABLED=False
SOLIQ_API_URL=
SOLIQ_API_TOKEN=
PUSH_NOTIFICATIONS_ENABLED=False
FCM_CREDENTIALS_FILE=

DEFAULT_FROM_EMAIL=noreply@example.com
EMAIL_ENABLED=False
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

PLATFORM_CLICK_SERVICE_ID=
PLATFORM_CLICK_MERCHANT_ID=
PLATFORM_CLICK_SECRET_KEY=
PLATFORM_PAYME_MERCHANT_ID=
PLATFORM_PAYME_KEY=

# Provider switches are fail-closed: False means no mock and no outbound call.
# Keep the AI and SMS-campaign routes unavailable until those providers launch;
# finance/payments and in-app notifications remain usable independently.
DISABLED_APPS=ai,campaigns
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_ENVIRONMENT=production
