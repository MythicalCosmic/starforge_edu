# Docker Compose interpolation only. Keep runtime secrets in the separate files below.
APP_IMAGE=starforge:REPLACE_WITH_COMMIT_SHA
POSTGRES_IMAGE=postgres:16-alpine@sha256:e013e867e712fec275706a6c51c966f0bb0c93cfa8f51000f85a15f9865a28cb
REDIS_IMAGE=redis:7-alpine@sha256:6ab0b6e7381779332f97b8ca76193e45b0756f38d4c0dcda72dbb3c32061ab99
MINIO_IMAGE=minio/minio@sha256:14cea493d9a34af32f524e538b8346cf79f3321eff8e708c1e2960462bd8936e

STARFORGE_APP_ENV_FILE=/root/starforge-deploy/app.env
STARFORGE_DB_ENV_FILE=/root/starforge-deploy/postgres.env
STARFORGE_MINIO_ENV_FILE=/root/starforge-deploy/minio.env
# Set only when PUSH_NOTIFICATIONS_ENABLED=True in app.env:
# STARFORGE_FIREBASE_CREDENTIALS_FILE=/root/starforge-deploy/secrets/firebase.json
